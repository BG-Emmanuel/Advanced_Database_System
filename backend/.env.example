# ================================================
# Buy237 Backend Configuration
# ================================================
# Copy this file to .env and fill in your values

# ================================================
# DATABASE CONFIGURATION
# ================================================

# Option 1: Using Supabase Connection String (Recommended)
# Get this from Supabase project dashboard (Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@[YOUR_PROJECT].supabase.co:5432/postgres

# Option 2: Using Individual Database Variables (Local/Alternative)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=buy237_db
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# ================================================
# APPLICATION CONFIGURATION
# ================================================

# Environment: development, staging, production
NODE_ENV=development

# Server port
PORT=5000

# Frontend URLs (comma-separated for multiple)
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# API Base URL (for generating image URLs, etc.)
API_BASE_URL=http://localhost:5000

# ================================================
# AUTHENTICATION
# ================================================

# JWT Secret (generate a strong random string)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# JWT Expiration
JWT_EXPIRES_IN=7d

# Google OAuth (for Google login)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ================================================
# PAYMENT GATEWAYS
# ================================================

# MTN Mobile Money Configuration
MTN_MOMO_API_KEY=your_mtn_momo_api_key
MTN_MOMO_SECRET=your_mtn_momo_secret
MTN_MOMO_WEBHOOK_SECRET=your_mtn_momo_webhook_secret

# Orange Money Configuration
ORANGE_MONEY_API_KEY=your_orange_money_api_key
ORANGE_MONEY_SECRET=your_orange_money_secret
ORANGE_MONEY_WEBHOOK_SECRET=your_orange_money_webhook_secret

# ================================================
# EMAIL CONFIGURATION (Nodemailer)
# ================================================

# Gmail Configuration (if using Gmail with App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# Or use SendGrid
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# ================================================
# FILE UPLOAD CONFIGURATION
# ================================================

# Max file size (in MB)
MAX_FILE_SIZE=10

# Allowed image types
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp

# Storage location
UPLOAD_DIR=./uploads

# ================================================
# LOGGING & MONITORING
# ================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable request logging
LOG_REQUESTS=true

# ================================================
# SECURITY
# ================================================

# CORS allowed hosts (overrides defaults)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://buy237.cm

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# ================================================
# FEATURE FLAGS
# ================================================

# Enable new features
ENABLE_WISHLIST=true
ENABLE_RATINGS=true
ENABLE_RECOMMENDATIONS=true
ENABLE_FLASH_SALES=true

# ================================================
# OPTIONAL: AWS S3 (if using cloud storage)
# ================================================

# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your_bucket_name
